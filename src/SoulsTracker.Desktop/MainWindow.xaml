<StackPanel Orientation="Horizontal"><Button Content="Choose…" Click="ChooseDeathsExport_Click" AutomationProperties.Name="Choose deaths text file" /><Button Margin="8,0,0,0" Content="Clear" Click="ClearDeathsExport_Click" AutomationProperties.Name="Clear deaths text file" /><CheckBox Margin="8,0,0,0" Content="Enable" IsChecked="{Binding IsDeathsExportEnabled, Mode=OneWay}" Checked="DeathsExportEnabled_Checked" Unchecked="DeathsExportEnabled_Unchecked" /></StackPanel>
                            <TextBlock Margin="0,10,0,0" Text="Boss list text file" /><TextBlock x:Name="BossExportFileNameTextBlock" Text="{Binding BossExportFileName, Mode=OneWay, TargetNullValue=No file selected.}" AutomationProperties.Name="Boss export file name" />
<StackPanel Orientation="Horizontal"><Button Content="Choose…" Click="ChooseBossExport_Click" AutomationProperties.Name="Choose boss text file" /><Button Margin="8,0,0,0" Content="Clear" Click="ClearBossExport_Click" AutomationProperties.Name="Clear boss text file" /><CheckBox Margin="8,0,0,0" Content="Enable" IsChecked="{Binding IsBossExportEnabled, Mode=OneWay}" Checked="BossExportEnabled_Checked" Unchecked="BossExportEnabled_Unchecked" /></StackPanel>
                            <TextBlock x:Name="TextExportStatusTextBlock" Style="{StaticResource MutedText}" Margin="0,8,0,0" Text="{Binding TextExportStatus, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#1B1F26" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,10">
            <TextBlock HorizontalAlignment="Right" Style="{StaticResource MutedText}">More at <Hyperlink x:Name="BeingKairoAttributionHyperlink" NavigateUri="https://www.beingkairo.com/" RequestNavigate="BeingKairoAttributionHyperlink_RequestNavigate" AutomationProperties.Name="Visit beingkairo.com (opens in default browser)" ToolTip="Open beingkairo.com in your default browser">beingkairo.com</Hyperlink></TextBlock>
        </Border>

        <Grid x:Name="HotkeyRecordingOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="20"
              Background="#A8000000"
              Visibility="{Binding IsHotkeyRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
              Focusable="True"
              AutomationProperties.Name="Manual hotkey recording">
            <Border Width="430" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#20242B" BorderBrush="#A78BFA" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0,0,9,0" Fill="#FF4D4D" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Currently recording input" />
                    </StackPanel>
                    <TextBlock Margin="0,18,0,0" Style="{StaticResource MutedText}" Text="Press the input that you want to use as a hotkey then click enter to save." />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedText}" Text="Press ESC to exit without saving" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
